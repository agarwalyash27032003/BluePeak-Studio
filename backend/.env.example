PORT=10000

# Option A — Standard connection (recommended on Windows if mongodb+srv fails with querySrv ECONNREFUSED)
# Atlas → Connect → Drivers → copy "Standard connection string" and replace <password>/<dbname>
MONGO_URL=mongodb://USER:PASSWORD@host1:27017,host2:27017,host3:27017/bluepeak?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority

# Option B — SRV connection (works when DNS supports SRV records)
# MONGO_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/bluepeak?retryWrites=true&w=majority

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ADMIN_SEED_EMAIL=admin@bluepeakstudio.in
ADMIN_SEED_PASSWORD=admin123
